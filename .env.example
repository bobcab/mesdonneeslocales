# Copiez ce fichier en .env (jamais commité) et renseignez vos identifiants FTP.

FTP_HOST=ftp.example.com
FTP_PORT=21
FTP_USER=
FTP_PASS=
# Répertoire racine sur le serveur (ex: "/" ou "/www" ou "/public_html")
FTP_REMOTE_DIR=/
# Mettez à true si le serveur exige FTPS (TLS)
FTP_SECURE=false

# Chemins distants à NE JAMAIS supprimer lors du deploy (relatifs à FTP_REMOTE_DIR, séparés par virgules)
# Utile pour préserver des dossiers gérés en dehors d'Astro (mviewer, anciens fichiers, etc.)
FTP_PROTECT=mviewer,geoserver,geonetwork

# Mettez à true pour simuler le déploiement sans rien modifier
FTP_DRY_RUN=false
