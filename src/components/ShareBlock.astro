---
import type { CollectionEntry } from 'astro:content';

interface Props {
  carto: CollectionEntry<'cartographies'>;
  /** URL canonique de la page (passée pour éviter de la recalculer). */
  pageUrl: string;
}

const { carto, pageUrl } = Astro.props;
const d = carto.data;

const embedCode = `<iframe src="${d.mapUrl}" width="100%" height="600" frameborder="0" loading="lazy" title="${d.title} — Mes données locales"></iframe>`;

const attribution = `Source : Mes données locales — L'Observatoire citoyen, d'après les données de ${d.source.name}`;

// Téléchargements : seulement si la carto a un GeoJSON public.
type Download = { label: string; url: string; format: string };
const downloads: Download[] = [
  ...(d.geojsonUrl
    ? [{ label: 'GeoJSON', url: d.geojsonUrl, format: 'application/geo+json' }]
    : []),
  ...(d.downloadFormats ?? []).map((url, i) => ({
    label: `Téléchargement ${i + 1}`,
    url,
    format: 'application/octet-stream',
  })),
];
---

<section aria-labelledby="share-title" class="share-block">
  <h2 id="share-title" class="share-block__title">Partager cette cartographie</h2>

  <div class="share-block__grid">
    <div class="share-block__card">
      <p class="share-block__label">Lien permanent</p>
      <input
        type="text"
        readonly
        value={pageUrl}
        class="share-block__input"
        data-share-input
        aria-label="Lien permanent vers cette cartographie"
      />
      <button
        type="button"
        class="btn-secondary share-block__btn"
        data-copy-link
        data-url={pageUrl}
      >
        Copier le lien
      </button>
    </div>

    <div class="share-block__card">
      <p class="share-block__label">&lt;/&gt; Intégrer (embed)</p>
      <textarea
        readonly
        rows="3"
        class="share-block__textarea"
        aria-label="Code HTML d'intégration"
      >{embedCode}</textarea>
      <button
        type="button"
        class="btn-secondary share-block__btn"
        data-copy-link
        data-url={embedCode}
      >
        Copier le code
      </button>
    </div>

    <div class="share-block__card">
      <p class="share-block__label">Télécharger les données</p>
      {downloads.length > 0 ? (
        <ul class="share-block__downloads">
          {downloads.map((dl) => (
            <li>
              <a
                href={dl.url}
                target="_blank"
                rel="noopener noreferrer"
                class="share-block__dl-link"
                download
              >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="share-block__dl-icon" aria-hidden="true">
                  <path d="M10.75 2.75a.75.75 0 0 0-1.5 0v8.614L6.295 8.235a.75.75 0 1 0-1.09 1.03l4.25 4.5a.75.75 0 0 0 1.09 0l4.25-4.5a.75.75 0 0 0-1.09-1.03l-2.955 3.129V2.75Z"/>
                  <path d="M3.5 12.75a.75.75 0 0 0-1.5 0v2.5A2.75 2.75 0 0 0 4.75 18h10.5A2.75 2.75 0 0 0 18 15.25v-2.5a.75.75 0 0 0-1.5 0v2.5c0 .69-.56 1.25-1.25 1.25H4.75c-.69 0-1.25-.56-1.25-1.25v-2.5Z"/>
                </svg>
                {dl.label}
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="share-block__none">
          Téléchargement direct non disponible. Les données sont consultables via la source officielle ci-dessus.
        </p>
      )}
    </div>
  </div>

  <div class="share-block__attribution">
    <p class="share-block__label share-block__label--inline">Mention d'attribution recommandée</p>
    <div class="share-block__attr-row">
      <code class="share-block__attr-code">{attribution}</code>
      <button
        type="button"
        class="share-block__attr-copy"
        data-copy-link
        data-url={attribution}
        aria-label="Copier la mention d'attribution"
      >
        Copier
      </button>
    </div>
  </div>
</section>

<style is:global>
  /* ShareBlock — Piste B : 3 cards filet (pattern B), boutons secondaires. */
  .share-block {
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-2xl);
  }
  .share-block__title {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: clamp(1.5rem, 2vw, 1.75rem);
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--color-ink-900);
    margin: 0 0 var(--space-lg) 0;
  }
  .share-block__grid {
    display: grid;
    gap: var(--space-md);
  }
  @media (min-width: 768px) {
    .share-block__grid { grid-template-columns: repeat(3, 1fr); }
  }
  .share-block__card {
    padding: var(--space-md) var(--space-lg);
    border: 0.5px solid var(--color-ink-200);
    border-radius: var(--radius-lg);
    background: var(--color-paper-50);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  .share-block__label {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ochre-600);
    margin: 0;
  }
  .share-block__input,
  .share-block__textarea {
    width: 100%;
    padding: 0.5rem 0.75rem;
    border: 0.5px solid var(--color-ink-200);
    border-radius: var(--radius-md);
    background: var(--color-paper-100);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.75rem;
    color: var(--color-ink-700);
    resize: none;
  }
  .share-block__btn {
    width: 100%;
    padding: 0.5rem 1rem;
    font-size: 0.8125rem;
    min-height: 36px;
  }
  .share-block__downloads {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .share-block__dl-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-ink-700);
    text-decoration: underline;
    text-decoration-color: var(--color-ochre-600);
    text-decoration-thickness: 1.5px;
    text-underline-offset: 3px;
  }
  .share-block__dl-link:hover {
    color: var(--color-ink-900);
    text-decoration-color: var(--color-ochre-700);
  }
  .share-block__dl-icon {
    height: 1rem;
    width: 1rem;
  }
  .share-block__none {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-ink-500);
    margin: 0;
  }

  .share-block__attribution {
    margin-top: var(--space-md);
    padding: var(--space-md) var(--space-lg);
    background: var(--color-paper-200);
    border-radius: var(--radius-lg);
  }
  .share-block__label--inline {
    margin-bottom: var(--space-xs);
  }
  .share-block__attr-row {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
  }
  .share-block__attr-code {
    flex: 1;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.75rem;
    color: var(--color-ink-700);
    word-break: break-word;
  }
  .share-block__attr-copy {
    flex-shrink: 0;
    background: transparent;
    border: none;
    cursor: pointer;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-ink-900);
    text-decoration: underline;
    text-decoration-color: var(--color-ochre-600);
    text-decoration-thickness: 1.5px;
    text-underline-offset: 3px;
  }
  .share-block__attr-copy:hover {
    color: var(--color-ochre-700);
    text-decoration-color: var(--color-ochre-700);
  }
</style>
