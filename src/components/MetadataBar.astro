---
import type { CollectionEntry } from 'astro:content';

interface Props {
  carto: CollectionEntry<'cartographies'>;
}

const { carto } = Astro.props;
const d = carto.data;

const dateFmt = new Intl.DateTimeFormat('fr-FR', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const frequencyLabels: Record<string, string> = {
  continuous: 'En continu',
  daily: 'Quotidienne',
  weekly: 'Hebdomadaire',
  monthly: 'Mensuelle',
  quarterly: 'Trimestrielle',
  yearly: 'Annuelle',
  irregular: 'Irrégulière',
};

const items = [
  d.lastDataUpdate
    ? {
        label: 'Dernière mise à jour',
        value: dateFmt.format(d.lastDataUpdate),
        datetime: d.lastDataUpdate.toISOString().slice(0, 10),
      }
    : null,
  {
    label: 'Source',
    value: d.source.name,
    href: d.source.url,
  },
  {
    label: 'Licence',
    value: d.source.license,
    href: d.source.licenseUrl,
  },
  {
    label: 'Fréquence',
    value: frequencyLabels[d.updateFrequency],
  },
].filter((i): i is NonNullable<typeof i> => i !== null);
---

<dl class="grid grid-cols-2 gap-4 rounded-sm border border-ink-300 bg-surface-muted p-4 text-sm md:grid-cols-4">
  {items.map((item) => (
    <div>
      <dt class="kicker">{item.label}</dt>
      <dd class="mt-1 text-ink-900 font-medium">
        {'datetime' in item && item.datetime ? (
          <time datetime={item.datetime}>{item.value}</time>
        ) : 'href' in item && item.href ? (
          <a href={item.href} target="_blank" rel="noopener noreferrer" class="no-underline hover:underline">
            {item.value}
          </a>
        ) : (
          item.value
        )}
      </dd>
    </div>
  ))}
</dl>
