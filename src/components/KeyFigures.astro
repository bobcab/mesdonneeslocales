---
interface KeyFigure {
  value: string;
  label: string;
}

interface Props {
  figures: KeyFigure[];
}

const { figures } = Astro.props;
---

{figures.length > 0 && (
  <section aria-labelledby="figures-title" class="my-8">
    <h2 id="figures-title" class="sr-only">Chiffres clés</h2>
    <div
      class:list={[
        'grid gap-4',
        figures.length === 1 && 'grid-cols-1',
        figures.length === 2 && 'grid-cols-1 sm:grid-cols-2',
        figures.length === 3 && 'grid-cols-1 sm:grid-cols-3',
        figures.length >= 4 && 'grid-cols-2 lg:grid-cols-4',
      ]}
    >
      {figures.map((f) => (
        <div class="rounded-xl bg-surface p-5 shadow-card">
          <p class="text-4xl font-bold text-ink-900 leading-none">{f.value}</p>
          <p class="mt-3 text-sm text-ink-500 leading-snug">{f.label}</p>
        </div>
      ))}
    </div>
  </section>
)}
