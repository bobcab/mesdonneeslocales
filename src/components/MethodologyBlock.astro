---
interface Methodology {
  provenance?: string;
  processing?: string;
  limits?: string;
  partner?: string;
}

interface Props {
  methodology?: Methodology;
}

const { methodology } = Astro.props;
if (!methodology) return null;

const items: Array<{ label: string; text: string }> = [];
if (methodology.provenance) items.push({ label: 'Provenance', text: methodology.provenance });
if (methodology.processing) items.push({ label: 'Traitement', text: methodology.processing });
if (methodology.limits) items.push({ label: 'Limites assumées', text: methodology.limits });
if (methodology.partner) items.push({ label: 'Partenaire thématique', text: methodology.partner });

if (items.length === 0) return null;
---

<section aria-labelledby="methodology-title" class="methodology-block">
  <h2 id="methodology-title" class="methodology-block__title">
    Méthodologie de cette cartographie
  </h2>

  <div class="methodology-block__grid">
    {items.map((it) => (
      <div class="methodology-block__item">
        <h3 class="methodology-block__label">{it.label}</h3>
        <p class="methodology-block__text">{it.text}</p>
      </div>
    ))}
  </div>

  <p class="methodology-block__footer">
    Pour notre approche générale, consultez la
    <a href="/methodologie/">méthodologie complète</a>.
  </p>
</section>

<style is:global>
  /* MethodologyBlock — charte Piste B §4.2 : prose directe, pas
     de card, kickers ocre, body Inter 1.75. */
  .methodology-block {
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-2xl);
  }
  .methodology-block__title {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: clamp(1.5rem, 2vw, 1.75rem);
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--color-ink-900);
    margin: 0 0 var(--space-lg) 0;
  }
  .methodology-block__grid {
    display: grid;
    gap: var(--space-lg);
  }
  @media (min-width: 768px) {
    .methodology-block__grid { grid-template-columns: 1fr 1fr; gap: var(--space-xl); }
  }
  .methodology-block__item {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  .methodology-block__label {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ochre-600);
    margin: 0;
  }
  .methodology-block__text {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--color-ink-700);
    margin: 0;
  }
  .methodology-block__footer {
    margin-top: var(--space-lg);
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--color-ink-400);
  }
  .methodology-block__footer a {
    color: var(--color-ink-700);
    text-decoration: underline;
    text-decoration-color: var(--color-ochre-600);
    text-decoration-thickness: 1.5px;
    text-underline-offset: 3px;
  }
</style>
