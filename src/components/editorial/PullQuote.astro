---
interface Props {
  author?: string;
  source?: string;
}

const { author, source } = Astro.props;
---

<figure class="my-12 border-l-4 border-brand-500 pl-8 not-prose">
  <blockquote class="display text-2xl md:text-3xl font-medium text-ink-900 tracking-tight leading-snug">
    « <slot /> »
  </blockquote>
  {(author || source) && (
    <figcaption class="mt-4 text-sm text-ink-500">
      {author && <span class="font-medium text-ink-700">{author}</span>}
      {author && source && <span> · </span>}
      {source && <cite class="not-italic">{source}</cite>}
    </figcaption>
  )}
</figure>
