---
interface Step {
  title: string;
  description: string;
}

interface Props {
  items: Step[];
}

const { items } = Astro.props;
---

<div class="not-prose my-12 grid gap-12 md:grid-cols-3">
  {items.map((item, i) => (
    <div>
      <div class="display text-5xl font-medium text-brand-500 mb-4">
        {String(i + 1).padStart(2, '0')}
      </div>
      <h3 class="text-xl font-semibold text-ink-900 mb-3 tracking-tight">{item.title}</h3>
      <p class="text-base text-ink-700 leading-relaxed">{item.description}</p>
    </div>
  ))}
</div>
