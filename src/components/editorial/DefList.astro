---
interface DefItem {
  term: string;
  description: string;
}

interface Props {
  items: DefItem[];
}

const { items } = Astro.props;
---

<dl class="def-list not-prose">
  {items.map((item) => (
    <div class="def-list__row">
      <dt class="def-list__term">{item.term}</dt>
      <dd class="def-list__desc">{item.description}</dd>
    </div>
  ))}
</dl>

<style is:global>
  /* DefList — liste de définitions à 2 colonnes. Charte §4 : pas
     de fond, pas de bordures, aération via gap généreux. */
  .def-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    margin-top: var(--space-xl);
    margin-bottom: var(--space-xl);
  }
  .def-list__row {
    display: grid;
    gap: var(--space-xs);
  }
  @media (min-width: 768px) {
    .def-list__row {
      grid-template-columns: 200px 1fr;
      gap: var(--space-lg);
    }
  }
  .def-list__term {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-ink-900);
    letter-spacing: -0.01em;
  }
  @media (min-width: 768px) {
    .def-list__term { padding-top: 0.125rem; }
  }
  .def-list__desc {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-ink-700);
    margin: 0;
  }
</style>
