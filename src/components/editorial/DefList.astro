---
interface DefItem {
  term: string;
  description: string;
}

interface Props {
  items: DefItem[];
}

const { items } = Astro.props;
---

<dl class="not-prose space-y-8 my-10">
  {items.map((item) => (
    <div class="grid gap-2 md:grid-cols-[200px_1fr] md:gap-8">
      <dt class="font-semibold text-ink-900 text-base md:pt-1">{item.term}</dt>
      <dd class="text-base text-ink-700 leading-relaxed">{item.description}</dd>
    </div>
  ))}
</dl>
