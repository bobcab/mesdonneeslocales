---
interface ReadingItem {
  href: string;
  label: string;
  description?: string;
  external?: boolean;
}

interface Props {
  items: ReadingItem[];
  title?: string;
}

const { items, title = 'Aller plus loin' } = Astro.props;
---

<section class="not-prose mt-16 pt-12 border-t border-ink-300/30">
  <p class="kicker mb-6 text-ink-500">{title}</p>
  <ul class="grid gap-4 md:grid-cols-2">
    {items.map((item) => (
      <li>
        <a
          href={item.href}
          target={item.external ? '_blank' : undefined}
          rel={item.external ? 'noopener noreferrer' : undefined}
          class="group block rounded-xl border border-ink-300/40 p-5 no-underline transition-all hover:border-brand-500 hover:bg-brand-50 hover:-translate-y-0.5"
        >
          <p class="font-semibold text-ink-900 group-hover:text-brand-700 mb-1 flex items-center gap-2">
            {item.label}
            <span aria-hidden="true" class="text-sm transition-transform group-hover:translate-x-1">→</span>
          </p>
          {item.description && (
            <p class="text-sm text-ink-700 leading-relaxed">{item.description}</p>
          )}
        </a>
      </li>
    ))}
  </ul>
</section>
