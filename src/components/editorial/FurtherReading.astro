---
interface ReadingItem {
  href: string;
  label: string;
  description?: string;
  external?: boolean;
}

interface Props {
  items: ReadingItem[];
  title?: string;
}

const { items, title = 'Aller plus loin' } = Astro.props;
---

<section class="further-reading not-prose">
  <p class="further-reading__title">{title}</p>
  <ul class="further-reading__list">
    {items.map((item) => (
      <li>
        <a
          href={item.href}
          target={item.external ? '_blank' : undefined}
          rel={item.external ? 'noopener noreferrer' : undefined}
          class="further-reading__card"
        >
          <p class="further-reading__label">
            {item.label}
            <span class="further-reading__arrow" aria-hidden="true">→</span>
          </p>
          {item.description && (
            <p class="further-reading__desc">{item.description}</p>
          )}
        </a>
      </li>
    ))}
  </ul>
</section>

<style is:global>
  /* FurtherReading — pattern carte plate (pattern A) : filet supérieur
     ink-100, cards sans fond avec soulignement ocre sur le titre. */
  .further-reading {
    margin-top: var(--space-3xl);
    padding-top: var(--space-xl);
    border-top: 0.5px solid var(--color-ink-100);
  }
  .further-reading__title {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ochre-600);
    margin: 0 0 var(--space-lg) 0;
  }
  .further-reading__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-md);
  }
  @media (min-width: 768px) {
    .further-reading__list {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-lg);
    }
  }
  .further-reading__card {
    display: block;
    padding: var(--space-md) 0;
    border-top: 0.5px solid var(--color-ink-100);
    text-decoration: none;
    color: var(--color-ink-900);
    transition: color 150ms ease;
  }
  .further-reading__card:hover {
    text-decoration: none;
  }
  .further-reading__label {
    margin: 0 0 0.25rem 0;
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-xs);
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 1.0625rem;
    color: var(--color-ink-900);
    letter-spacing: -0.01em;
    text-decoration: underline;
    text-decoration-color: var(--color-ochre-600);
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
    transition: color 150ms ease, text-decoration-color 150ms ease;
  }
  .further-reading__card:hover .further-reading__label {
    color: var(--color-ochre-700);
    text-decoration-color: var(--color-ochre-700);
  }
  .further-reading__arrow {
    font-size: 0.875rem;
    transition: transform 150ms ease;
  }
  .further-reading__card:hover .further-reading__arrow {
    transform: translateX(3px);
  }
  .further-reading__desc {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--color-ink-700);
  }
</style>
