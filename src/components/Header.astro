---
// Import du SVG pur du wordmark (sans tagline, sans filet) en raw string
// pour pouvoir l'inliner via set:html et qu'il hérite de currentColor.
import mdlSvg from '../assets/logo/mdl-wordmark-pure.svg?raw';
---

<header class="site-header">
  <div class="site-header__inner">
    {/* LOGO : wordmark SVG + filet ocre + tagline texte */}
    <a href="/" class="site-header__logo" aria-label="mdl, Mes données locales — accueil">
      <span class="site-header__wordmark" set:html={mdlSvg} />
      <span class="site-header__separator" aria-hidden="true"></span>
      <span class="site-header__tagline">Savoir c'est pouvoir</span>
    </a>

    {/* NAV : 5 items principaux + CTA don en lien souligné ocre */}
    <nav class="site-header__nav" aria-label="Navigation principale">
      <a href="/cartographies/" class="site-header__nav-item">Cartographies</a>
      <a href="/a-propos/" class="site-header__nav-item">À propos</a>
      <a href="/methodologie/" class="site-header__nav-item">Méthodologie</a>
      <a href="/je-participe/" class="site-header__nav-item">Je participe</a>
      <a href="/contact/" class="site-header__nav-item">Contact</a>
      <a
        href="/je-participe/#don"
        class="site-header__nav-item site-header__nav-item--accent"
      >
        Faire un don
      </a>
    </nav>
  </div>
</header>
