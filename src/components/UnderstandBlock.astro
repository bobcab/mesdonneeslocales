---
interface Props {
  says: string[];
  saysNot: string[];
}

const { says, saysNot } = Astro.props;

if (says.length === 0 && saysNot.length === 0) return null;
---

<section aria-labelledby="understand-title" class="my-12">
  <h2 id="understand-title" class="text-xl font-bold text-ink-900 mb-6">Comprendre la donnée</h2>

  <div class="grid gap-6 md:grid-cols-2">
    {says.length > 0 && (
      <div class="rounded-sm border-l-4 border-success-500 bg-success-50 p-5">
        <h3 class="text-base font-semibold text-ink-900 mb-3">Ce que dit cette cartographie</h3>
        <ul class="space-y-2 text-sm text-ink-700">
          {says.map((point) => (
            <li class="flex gap-2">
              <span aria-hidden="true" class="mt-1 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-success-500"></span>
              <span>{point}</span>
            </li>
          ))}
        </ul>
      </div>
    )}

    {saysNot.length > 0 && (
      <div class="rounded-sm border-l-4 border-warning-500 bg-warning-50 p-5">
        <h3 class="text-base font-semibold text-ink-900 mb-3">Ce qu'elle ne dit pas</h3>
        <ul class="space-y-2 text-sm text-ink-700">
          {saysNot.map((point) => (
            <li class="flex gap-2">
              <span aria-hidden="true" class="mt-1 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-warning-500"></span>
              <span>{point}</span>
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
</section>
