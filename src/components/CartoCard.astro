---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  carto: CollectionEntry<'cartographies'>;
  variant?: 'featured' | 'catalog' | 'list' | 'hero' | 'secondary';
}

const { carto, variant = 'catalog' } = Astro.props;
const d = carto.data;
const slug = carto.id.replace(/\.md$/, '');
const pageUrl = `/cartographies/${slug}/`;
const shareLink = d.shareUrl ?? pageUrl;

const text = d.shortDescription ?? d.description;

// Piste A : "new" en ambre (signal éditorial d'attention, pas en brand pour ne pas concurrencer
// le bouton "J'accède"). Contraste ambre-500/ink-900 = 9.66, AA OK.
const statusConfig = {
  new: { label: 'Nouveau', class: 'bg-accent-500 text-ink-900' },
  updated: { label: 'Actualisé', class: 'bg-success-500 text-white' },
  maintenance: { label: 'En maintenance', class: 'bg-accent-700 text-white' },
} as const;

const badge = statusConfig[d.status];
const isMaintenance = d.status === 'maintenance';

const dateFmt = new Intl.DateTimeFormat('fr-FR', {
  month: 'short',
  year: 'numeric',
});

const FREQ_LABELS: Record<string, string> = {
  continuous: 'Continue',
  daily: 'Quotidienne',
  weekly: 'Hebdo.',
  monthly: 'Mensuelle',
  quarterly: 'Trimestrielle',
  yearly: 'Annuelle',
  irregular: 'Irrégulière',
};

// Échelle dérivée du spatialCoverage — doit matcher la logique de CartographyFilter.astro
function getScale(): string {
  const sc = d.spatialCoverage.toLowerCase();
  if (sc.includes('commune')) return 'Par commune';
  if (sc.includes('département') || sc.includes('departement')) return 'Par département';
  return "Par site / établissement";
}

const searchHaystack = [
  d.title,
  d.shortDescription ?? '',
  d.description,
  d.category,
  ...d.subCategories,
  ...d.keywords,
  d.source.name,
  d.author,
].join(' ');

const dataAttrs = {
  'data-carto-card': true,
  'data-search': searchHaystack,
  'data-category': d.category,
  'data-scale': getScale(),
  'data-freq': d.updateFrequency,
  'data-type': d.typeapp,
};

const isList = variant === 'list';
const isHero = variant === 'hero';
const isSecondary = variant === 'secondary';
---

{isHero ? (
  /* ============================================================
     Vue HERO (Piste B pattern A) : carte plate vedette, image ratio 1:1,
     titre Playfair Roman dessous, lien souligné ocre, pas d'ombre.
     ============================================================ */
  <a href={pageUrl} {...dataAttrs} class="carto-card carto-card--hero">
    {d.image && (
      <div class="carto-card__image">
        <Image
          src={d.image}
          alt={d.imageAlt}
          widths={[600, 900, 1200]}
          sizes="(max-width: 1024px) 100vw, 50vw"
          class="carto-card__img"
          loading="eager"
        />
        {d.status === 'new' && (
          <span class="carto-card__badge">Nouveau</span>
        )}
      </div>
    )}
    <div class="carto-card__body">
      <p class="caption caption-ochre carto-card__cat">{d.category}</p>
      <h3 class="carto-card__title carto-card__title--lg">{d.title}</h3>
      <p class="carto-card__lead">{text}</p>
      <span class="carto-card__cta">
        Découvrir la cartographie <span aria-hidden="true">→</span>
      </span>
    </div>
  </a>
) : isSecondary ? (
  /* ============================================================
     Vue SECONDARY (Piste B pattern A) : carte plate horizontale.
     Image carrée à gauche, texte sobre à droite, pas d'ombre.
     ============================================================ */
  <a href={pageUrl} {...dataAttrs} class="carto-card carto-card--secondary">
    {d.image && (
      <div class="carto-card__image carto-card__image--side">
        <Image
          src={d.image}
          alt={d.imageAlt}
          widths={[300, 500]}
          sizes="200px"
          class="carto-card__img"
          loading="lazy"
        />
      </div>
    )}
    <div class="carto-card__body">
      <p class="caption caption-ochre carto-card__cat">
        {d.category}
        {d.status === 'new' && <span class="carto-card__cat-tag">Nouveau</span>}
      </p>
      <h3 class="carto-card__title">{d.title}</h3>
      <p class="carto-card__lead carto-card__lead--sm">{text}</p>
      <span class="carto-card__cta carto-card__cta--sm">
        Voir la cartographie <span aria-hidden="true">→</span>
      </span>
    </div>
  </a>
) : isList ? (
  /* ============================================================
     Vue LISTE : layout horizontal compact
     ============================================================ */
  <article
    {...dataAttrs}
    class="group flex flex-col gap-4 overflow-hidden rounded-2xl bg-surface p-4 shadow-card transition-all hover:shadow-card-hover sm:flex-row sm:items-center sm:gap-6 sm:p-5"
  >
    {d.image && (
      <a href={pageUrl} class="block aspect-[16/10] w-full overflow-hidden bg-brand-50 rounded-xl no-underline sm:aspect-square sm:w-32 sm:shrink-0">
        <Image
          src={d.image}
          alt={d.imageAlt}
          widths={[200, 400]}
          sizes="200px"
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
          loading="lazy"
        />
      </a>
    )}

    <div class="flex flex-1 flex-col gap-2 min-w-0">
      <div class="flex flex-wrap items-center gap-2 text-xs">
        <span class="pill-brand">{d.category}</span>
        {d.status === 'new' && <span class={`px-2.5 py-0.5 rounded-full font-medium text-xs ${badge.class}`}>Nouveau</span>}
        <span class="text-ink-500">{d.typeapp}</span>
      </div>

      <h3 class="text-lg font-semibold text-ink-900 truncate">
        <a href={pageUrl} class="text-ink-900 no-underline hover:text-brand-500">{d.title}</a>
      </h3>

      <p class="text-sm text-ink-700 line-clamp-2">{text}</p>

      <p class="text-xs text-ink-500">
        <span class="font-medium">{d.source.name}</span>
        {' · '}
        <span>MAJ {FREQ_LABELS[d.updateFrequency] ?? d.updateFrequency}</span>
        {d.lastDataUpdate && (
          <>
            {' · '}
            <time datetime={d.lastDataUpdate.toISOString().slice(0, 10)}>{dateFmt.format(d.lastDataUpdate)}</time>
          </>
        )}
      </p>
    </div>

    <div class="flex shrink-0 flex-wrap gap-2 sm:flex-col">
      {isMaintenance ? (
        <button type="button" class="btn-primary opacity-60 cursor-not-allowed text-sm" disabled>
          Bientôt disponible
        </button>
      ) : (
        <a href={pageUrl} class="btn-primary text-sm">J'accède</a>
      )}
    </div>
  </article>
) : (
  /* ============================================================
     Vue GRILLE (featured + catalog) : card verticale enrichie
     ============================================================ */
  <article
    {...dataAttrs}
    class:list={[
      'group flex h-full flex-col overflow-hidden rounded-2xl bg-surface shadow-card transition-all hover:shadow-card-hover hover:-translate-y-0.5',
      variant === 'featured' && 'min-h-[420px]',
    ]}
  >
    {d.image && (
      <a href={pageUrl} class="block relative overflow-hidden bg-brand-50 aspect-[16/10] no-underline">
        <Image
          src={d.image}
          alt={d.imageAlt}
          widths={[400, 600, 800]}
          sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
          loading="lazy"
        />
        <span class:list={['absolute top-3 right-3 px-3 py-1 text-xs font-semibold uppercase tracking-wide', badge.class]}>
          {badge.label}
        </span>
      </a>
    )}

    <div class="flex flex-1 flex-col p-6">
      <div class="mb-3 flex flex-wrap items-center gap-2 text-xs">
        <span class="pill-brand">{d.category}</span>
        <span class="text-ink-500 uppercase tracking-wide">{d.typeapp}</span>
      </div>

      <h3 class="mb-3 text-xl font-semibold text-ink-900">
        <a href={pageUrl} class="text-ink-900 no-underline hover:text-brand-500">{d.title}</a>
      </h3>

      <p class="mb-4 flex-1 text-sm text-ink-700 leading-relaxed line-clamp-5">{text}</p>

      {/* Trois pills métadonnées (Synthèse UX p.11) */}
      <div class="mb-4 flex flex-wrap gap-1.5 text-xs">
        <span class="pill">MAJ {FREQ_LABELS[d.updateFrequency] ?? d.updateFrequency}</span>
        <span class="pill">{getScale()}</span>
      </div>

      <p class="mb-4 text-xs text-ink-500">
        <span class="font-medium">Source :</span> {d.source.name}
        {d.lastDataUpdate && (
          <>
            {' · '}
            <span>MAJ <time datetime={d.lastDataUpdate.toISOString().slice(0, 10)}>{dateFmt.format(d.lastDataUpdate)}</time></span>
          </>
        )}
      </p>

      <div class="flex flex-wrap gap-2">
        {isMaintenance ? (
          <button type="button" class="btn-primary opacity-60 cursor-not-allowed" disabled>
            Bientôt disponible
          </button>
        ) : (
          <>
            <a href={pageUrl} class="btn-primary">J'accède</a>
            <button type="button" class="btn-outline" data-copy-link data-url={shareLink}>
              Je copie le lien
            </button>
          </>
        )}
      </div>
    </div>
  </article>
)}

<style is:global>
  /* ============================================================
     CartoCard variants HERO & SECONDARY — Piste B pattern A
     « carte plate » : pas de fond coloré, pas de bordure, pas
     d'ombre. Hiérarchie par typographie + image + soulignement ocre.
     ============================================================ */
  .carto-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    text-decoration: none;
    color: var(--color-ink-900);
    background: transparent;
    transition: opacity 200ms ease;
  }
  .carto-card:hover {
    text-decoration: none;
  }

  .carto-card--secondary {
    flex-direction: row;
    align-items: flex-start;
    gap: var(--space-md);
  }

  .carto-card__image {
    position: relative;
    overflow: hidden;
    background: var(--color-paper-200);
    aspect-ratio: 1 / 1;
    border-radius: var(--radius-lg);
  }
  .carto-card--hero .carto-card__image {
    aspect-ratio: 4 / 5;
  }
  .carto-card__image--side {
    flex-shrink: 0;
    width: 35%;
    max-width: 180px;
  }
  @media (max-width: 640px) {
    .carto-card__image--side {
      width: 40%;
    }
  }
  .carto-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 500ms ease;
  }
  .carto-card:hover .carto-card__img {
    transform: scale(1.02);
  }

  .carto-card__badge {
    position: absolute;
    top: var(--space-md);
    right: var(--space-md);
    background: var(--color-ochre-100);
    color: var(--color-ochre-800);
    padding: 4px 10px;
    border-radius: var(--radius-sm);
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .carto-card__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    flex: 1;
    min-width: 0;
  }

  .carto-card__cat {
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
  }
  .carto-card__cat-tag {
    color: var(--color-ochre-700);
    background: var(--color-ochre-100);
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    text-transform: uppercase;
    font-size: 0.625rem;
    letter-spacing: 0.1em;
    font-weight: 500;
  }

  .carto-card__title {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 1.375rem;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--color-ink-900);
    margin: 0;
    transition: color 150ms ease;
  }
  .carto-card__title--lg {
    font-size: clamp(1.625rem, 3vw, 2rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
  }
  .carto-card:hover .carto-card__title {
    color: var(--color-ochre-700);
  }

  .carto-card__lead {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-ink-700);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .carto-card--hero .carto-card__lead {
    font-size: 1rem;
    -webkit-line-clamp: 3;
    line-clamp: 3;
  }
  .carto-card__lead--sm {
    font-size: 0.875rem;
    -webkit-line-clamp: 2;
    line-clamp: 2;
  }

  .carto-card__cta {
    margin-top: auto;
    padding-top: var(--space-xs);
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.9375rem;
    color: var(--color-ink-900);
    text-decoration: underline;
    text-decoration-color: var(--color-ochre-600);
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
    transition: color 150ms ease, text-decoration-color 150ms ease;
  }
  .carto-card__cta--sm {
    font-size: 0.8125rem;
  }
  .carto-card:hover .carto-card__cta {
    color: var(--color-ochre-700);
    text-decoration-color: var(--color-ochre-700);
  }
</style>
