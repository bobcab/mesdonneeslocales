---
import { getCollection, type CollectionEntry } from 'astro:content';

interface Props {
  carto: CollectionEntry<'cartographies'>;
}

const { carto } = Astro.props;
const d = carto.data;

// Cartographies liées : même catégorie, hors page courante
const allCartos = await getCollection('cartographies');
const related = allCartos
  .filter((c) => c.id !== carto.id && c.data.category === d.category)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);
---

<section aria-labelledby="related-title" class="related-block">
  {d.furtherReading.length > 0 && (
    <div class="related-block__col">
      <h2 id="related-title" class="related-block__title">Sources et références</h2>
      <ul class="related-block__list">
        {d.furtherReading.map((link) => (
          <li>
            <a href={link.url} target="_blank" rel="noopener noreferrer" class="related-block__link">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}

  {related.length > 0 && (
    <div class="related-block__col">
      <h2 class="related-block__title">
        Autres cartographies « {d.category} »
      </h2>
      <ul class="related-block__list">
        {related.map((c) => {
          const slug = c.id.replace(/\.md$/, '');
          return (
            <li>
              <a href={`/cartographies/${slug}/`} class="related-block__link">
                {c.data.title}
              </a>
            </li>
          );
        })}
        <li class="related-block__catalog">
          <a href="/cartographies/" class="btn-tertiary">
            Voir toutes les cartographies <span aria-hidden="true">→</span>
          </a>
        </li>
      </ul>
    </div>
  )}
</section>

<style is:global>
  /* RelatedBlock — Piste B : 2 colonnes simples, liens soulignement ocre. */
  .related-block {
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-2xl);
    display: grid;
    gap: var(--space-xl);
  }
  @media (min-width: 768px) {
    .related-block { grid-template-columns: 1fr 1fr; }
  }
  .related-block__col {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .related-block__title {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 1.25rem;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--color-ink-900);
    margin: 0;
  }
  .related-block__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  .related-block__link {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--color-ink-700);
    text-decoration: underline;
    text-decoration-color: var(--color-ochre-600);
    text-decoration-thickness: 1.5px;
    text-underline-offset: 3px;
    transition: color 150ms ease, text-decoration-color 150ms ease;
  }
  .related-block__link:hover {
    color: var(--color-ink-900);
    text-decoration-color: var(--color-ochre-700);
  }
  .related-block__catalog {
    margin-top: var(--space-md);
  }
</style>
