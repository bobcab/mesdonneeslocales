---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CartoCard from '../../components/CartoCard.astro';
import CartographyFilter from '../../components/CartographyFilter.astro';
import UpcomingCard from '../../components/UpcomingCard.astro';
import ExplorationAlternative from '../../components/ExplorationAlternative.astro';
import CopyLinkScript from '../../components/CopyLinkScript.astro';

const cartos = (await getCollection('cartographies')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<Base
  title="Toutes les cartographies"
  description="Découvrez toutes les cartographies thématiques de données publiques mises à disposition par L'Observatoire citoyen."
>
  <article class="py-8 md:py-12">
    <div class="container-page max-w-7xl">
      <Breadcrumbs
        items={[
          { href: '/', label: 'Accueil' },
          { label: 'Toutes les cartographies' },
        ]}
      />

      <header class="mb-8 flex flex-wrap items-baseline justify-between gap-3">
        <div>
          <h1 class="text-3xl font-bold text-ink-900 md:text-4xl">Toutes les cartographies</h1>
          <p class="mt-2 max-w-3xl text-ink-700">
            Les données publiques cartographiées et qualifiées par L'Observatoire citoyen. Toutes
            accessibles sans inscription, sous licence ouverte.
          </p>
        </div>
        <div class="text-right text-sm text-ink-500">
          <p class="kicker">Total</p>
          <p class="text-2xl font-bold text-ink-900">{cartos.length}</p>
          <p>cartographie{cartos.length > 1 ? 's' : ''} disponible{cartos.length > 1 ? 's' : ''}</p>
        </div>
      </header>

      {/* Barre de recherche globale */}
      <div class="mb-8 rounded-sm border border-ink-300 bg-surface p-4">
        <label for="carto-q" class="sr-only">Rechercher une cartographie</label>
        <div class="relative">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 20 20"
            fill="currentColor"
            class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 h-5 w-5 text-ink-500"
            aria-hidden="true"
          >
            <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z" clip-rule="evenodd"/>
          </svg>
          <input
            type="search"
            id="carto-q"
            name="q"
            placeholder="Chercher une cartographie : prison, eau, nucléaire, santé…"
            autocomplete="off"
            class="w-full rounded-sm border-0 bg-surface-muted py-3 pl-10 pr-4 text-ink-900 placeholder:text-ink-500 focus:outline-none focus:ring-2 focus:ring-brand-500/30"
          />
        </div>
      </div>

      {/* Layout principal : sidebar filtres + grille résultats */}
      <div class="grid gap-8 lg:grid-cols-[260px_1fr]">
        {/* Sidebar filtres */}
        <CartographyFilter cartos={cartos} />

        {/* Main : compteur + toggle vue + résultats */}
        <div>
          <div class="mb-6 flex flex-wrap items-baseline justify-between gap-2">
            <p class="text-sm text-ink-700">
              <span class="font-semibold text-ink-900"><span data-carto-count>{cartos.length}</span> cartographie{cartos.length > 1 ? 's' : ''}</span>
              {' · '}
              <span data-active-filters class="text-ink-500">aucun filtre actif</span>
            </p>

            {/* Toggle Grille / Liste */}
            <div role="group" aria-label="Mode d'affichage" class="inline-flex rounded-sm border border-ink-300 bg-surface p-0.5">
              <button
                type="button"
                data-view-toggle
                data-view="grid"
                aria-pressed="true"
                class="inline-flex items-center gap-1.5 rounded-sm px-3 py-1.5 text-sm font-medium text-ink-700 transition-colors data-[active]:bg-brand-500 data-[active]:text-white"
                data-active
              >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4" aria-hidden="true">
                  <path d="M3 3.75A.75.75 0 0 1 3.75 3h3a.75.75 0 0 1 .75.75v3a.75.75 0 0 1-.75.75h-3A.75.75 0 0 1 3 6.75v-3Zm0 7A.75.75 0 0 1 3.75 10h3a.75.75 0 0 1 .75.75v3a.75.75 0 0 1-.75.75h-3a.75.75 0 0 1-.75-.75v-3Zm7-7A.75.75 0 0 1 10.75 3h3a.75.75 0 0 1 .75.75v3a.75.75 0 0 1-.75.75h-3a.75.75 0 0 1-.75-.75v-3Zm0 7a.75.75 0 0 1 .75-.75h3a.75.75 0 0 1 .75.75v3a.75.75 0 0 1-.75.75h-3a.75.75 0 0 1-.75-.75v-3Z"/>
                </svg>
                Grille
              </button>
              <button
                type="button"
                data-view-toggle
                data-view="list"
                aria-pressed="false"
                class="inline-flex items-center gap-1.5 rounded-sm px-3 py-1.5 text-sm font-medium text-ink-700 transition-colors data-[active]:bg-brand-500 data-[active]:text-white"
              >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4" aria-hidden="true">
                  <path fill-rule="evenodd" d="M2 4.75A.75.75 0 0 1 2.75 4h14.5a.75.75 0 0 1 0 1.5H2.75A.75.75 0 0 1 2 4.75ZM2 10a.75.75 0 0 1 .75-.75h14.5a.75.75 0 0 1 0 1.5H2.75A.75.75 0 0 1 2 10Zm0 5.25a.75.75 0 0 1 .75-.75h14.5a.75.75 0 0 1 0 1.5H2.75a.75.75 0 0 1-.75-.75Z" clip-rule="evenodd"/>
                </svg>
                Liste
              </button>
            </div>
          </div>

          {/* Message vide */}
          <div
            role="status"
            aria-live="polite"
            class="hidden mb-8 rounded-sm border-l-4 border-warning-500 bg-warning-50 p-5"
            data-carto-empty
          >
            <p class="font-semibold text-ink-900 mb-1">Aucune cartographie ne correspond à votre recherche</p>
            <p class="text-sm text-ink-700">
              Essayez d'autres mots-clés ou réinitialisez les filtres. Vous pouvez aussi
              <a href="mailto:contact@mesdonneeslocales.fr?subject=Proposition%20de%20cartographie">proposer une thématique</a>.
            </p>
          </div>

          {/* Résultats — DEUX rendus séparés (grille / liste), le JS toggle l'un ou l'autre */}
          <div data-view-grid class="grid gap-6 sm:grid-cols-2 xl:grid-cols-3">
            {cartos.map((carto) => <CartoCard carto={carto} variant="catalog" />)}
            <UpcomingCard />
          </div>

          <div data-view-list class="hidden flex-col gap-4">
            {cartos.map((carto) => <CartoCard carto={carto} variant="list" />)}
          </div>
        </div>
      </div>

      <ExplorationAlternative />
    </div>
  </article>

  <CopyLinkScript />
</Base>

<script>
  /**
   * Gestion du toggle Grille / Liste :
   *  - persisté dans localStorage + URL state (?view=grid|list)
   *  - bascule la visibilité des 2 conteneurs (grid vs list)
   *  - le filtrage (CartographyFilter) ne dépend pas de la vue car les data-attributes sont
   *    présents sur les cards des DEUX conteneurs ; le compteur additionne les visibles d'un seul.
   */

  const STORAGE_KEY = 'mdl-catalog-view';

  function getInitialView(): 'grid' | 'list' {
    const params = new URLSearchParams(window.location.search);
    const fromUrl = params.get('view');
    if (fromUrl === 'grid' || fromUrl === 'list') return fromUrl;
    try {
      const fromStorage = localStorage.getItem(STORAGE_KEY);
      if (fromStorage === 'grid' || fromStorage === 'list') return fromStorage;
    } catch {
      // localStorage indisponible (mode privé, etc.) — fallback grid
    }
    return 'grid';
  }

  function applyView(view: 'grid' | 'list') {
    const grid = document.querySelector<HTMLElement>('[data-view-grid]');
    const list = document.querySelector<HTMLElement>('[data-view-list]');
    if (!grid || !list) return;

    if (view === 'grid') {
      grid.classList.remove('hidden');
      grid.classList.add('grid');
      list.classList.add('hidden');
      list.classList.remove('flex');
    } else {
      grid.classList.add('hidden');
      grid.classList.remove('grid');
      list.classList.remove('hidden');
      list.classList.add('flex');
    }

    // État visuel des boutons
    document.querySelectorAll<HTMLButtonElement>('[data-view-toggle]').forEach((btn) => {
      const active = btn.dataset.view === view;
      btn.setAttribute('aria-pressed', String(active));
      if (active) btn.setAttribute('data-active', '');
      else btn.removeAttribute('data-active');
    });

    // Mémoriser
    document.documentElement.dataset.cartoView = view;
    try {
      localStorage.setItem(STORAGE_KEY, view);
    } catch {}

    // Sync URL
    const url = new URL(window.location.href);
    if (view === 'list') url.searchParams.set('view', 'list');
    else url.searchParams.delete('view');
    window.history.replaceState(null, '', url.toString());
  }

  function initView() {
    applyView(getInitialView());
    document.querySelectorAll<HTMLButtonElement>('[data-view-toggle]').forEach((btn) => {
      btn.addEventListener('click', () => applyView(btn.dataset.view as 'grid' | 'list'));
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initView);
  } else {
    initView();
  }
</script>
