---
import Base from '../layouts/Base.astro';
---

<Base
  title="Page introuvable"
  description="La page que vous cherchez n'existe pas ou a été déplacée."
>
  <section class="py-20">
    <div class="container-page max-w-2xl text-center">
      <p class="text-7xl font-bold text-brand-500 mb-4">404</p>
      <h1 class="text-3xl font-bold text-ink-900 mb-4">Page introuvable</h1>
      <p class="text-ink-700 mb-10">
        Désolé, la page que vous cherchez n'existe pas ou a été déplacée.
        Vous pouvez revenir à l'accueil ou explorer nos cartographies.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/" class="btn-primary">Retour à l'accueil</a>
        <a href="/cartographies/" class="btn-outline">Voir les cartographies</a>
      </div>
    </div>
  </section>
</Base>
