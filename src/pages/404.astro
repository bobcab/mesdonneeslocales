---
import Base from '../layouts/Base.astro';
---

<Base
  title="Page introuvable"
  description="La page que vous cherchez n'existe pas ou a été déplacée."
>
  <section class="not-found">
    <div class="container-prose not-found__inner">
      <p class="not-found__code">404</p>
      <h1 class="display-italic not-found__title">Page introuvable.</h1>
      <p class="not-found__lead">
        Désolé, la page que vous cherchez n'existe pas ou a été déplacée. Vous pouvez revenir
        à l'accueil ou explorer nos cartographies.
      </p>
      <div class="not-found__actions">
        <a href="/" class="btn-primary">Retour à l'accueil</a>
        <a href="/cartographies/" class="btn-secondary">Voir les cartographies</a>
      </div>
    </div>
  </section>
</Base>

<style is:global>
  .not-found {
    padding-top: var(--space-3xl);
    padding-bottom: var(--space-3xl);
  }
  .not-found__inner {
    text-align: center;
  }
  .not-found__code {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 900;
    font-size: clamp(5rem, 12vw, 8rem);
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--color-ochre-600);
    margin: 0 0 var(--space-md) 0;
  }
  .not-found__title {
    font-size: clamp(2rem, 5vw, 3rem);
    color: var(--color-ink-900);
    margin: 0 0 var(--space-md) 0;
  }
  .not-found__lead {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    line-height: 1.75;
    color: var(--color-ink-700);
    margin: 0 0 var(--space-xl) 0;
  }
  .not-found__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-md);
  }
</style>
